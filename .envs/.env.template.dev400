# Environment variables for Robot Framework TN5250 tests
# Copy this file to .env.LPAR_NAME (e.g., .env.dev400, .env.eur400a)
# and customize for your specific LPAR

TN5250_HOST=host_name_or_IP
TN5250_USER=user_profile
TN5250_PASS=password
TN5250_DEVNAME=optional_device_name
TN5250_MAP=optional_keyboard_map_number
TN5250_SSL=0_or_1_for_SSL