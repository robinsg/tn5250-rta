#!/usr/bin/env bash
# Environment variables for Robot Framework TN5250 tests
# Copy this file to .env.sh.LPAR_NAME (e.g., .env.sh.dev400, .env.sh.prod400)
# and customize for your specific LPAR

export TN5250_HOST=lpar_name_or_IP
export TN5250_USER=user_profile
export TN5250_PASS=password
export TN5250_DEVNAME=optional_device_name
export TN5250_MAP=optional_keyboard_map_number
export TN5250_SSL=0_or_1_for_SSL
