{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Robot Framework Debug",
            "type": "python",
            "request": "launch",
            "module": "robot",
            "args": [
                "--outputdir", "results",
                "tests/login.robot"
          ],
      "console": "integratedTerminal",
      "justMyCode": false
        },
        {
            "name": "Run Current Robot Suite",
            "type": "robotcode",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "target": "${file}",
            "args": [
                "--outputdir", "results",
                "--loglevel", "INFO"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Run All Tests",
            "type": "robotcode",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "target": ".",
            "args": [
                "--outputdir", "results"
            ],
            "console": "integratedTerminal"
        }
    ]
}