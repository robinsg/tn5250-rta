{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run current Robot file",
            "type": "python",
            "request": "launch",
            "module": "robot.run",
            "args": ["${file}"],
            "console": "integratedTerminal"
        },
        {
            "name": "Robot Framework Debug",
            "type": "python",
            "request": "launch",
            "module": "robot",
            "args": [
                "--outputdir", "results",
                "tests/login.robot"
          ],
      "console": "integratedTerminal",
      "justMyCode": false
        }
    ]
}