{
  "name": "Robot TN5250 Dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "d-biehl.robotcode",   // Robot Framework Syntax
        "ms-python.python"     // Python Support
      ]
    }
  },
  // Configure git and setup container on creation
  // Host entries are managed via .devcontainer/hosts.conf and applied at startup
  "runArgs": [
    "--network=host"
  ],
  "postCreateCommand": "bash .devcontainer/setup-hosts.sh && git config --global user.name 'Your Name' && git config --global user.email 'your.email@example.com' && echo 'Container Ready! TN5250 installed.'",
  "remoteUser": "root"
}
