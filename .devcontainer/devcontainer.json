{
  "name": "Robot TN5250 Dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      },
      "extensions": [
        "d-biehl.robotcode",   // Robot Framework Syntax
        "ms-python.python"     // Python Support
      ]
    }
  },
  // Configure git and setup container on creation
  // Add hostnames to container's /etc/hosts at runtime (replace IPs as needed)
  "runArgs": [
    "--network=host",
    "--add-host=eur400a:172.16.8.41",
    "--add-host=eur400t:172.16.8.43"
  ],
  "postCreateCommand": "git config --global user.name 'Glenn Robinson' && git config --global user.email 'Glenn.Robinson@rsipvm.com' && echo 'Container Ready! TN5250 installed.'",
  "remoteUser": "root"
}