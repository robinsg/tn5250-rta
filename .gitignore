# --- Robot Framework Artifacts ---
# Don't copy old test reports into the new image
results/**/*.xml
results/**/*.html
results/**/*.png
results/**/*.txt
log.html
report.html
output.xml
screenshots/
# Keep directory structure but ignore generated files
!results/**/suites/.gitkeep
!results/**/screenshots/.gitkeep

# --- LPAR-specific test files ---
# Ignore .robot files in all tests subdirectories
tests/**/*.robot
# But keep common tests
!tests/common/*.robot

# --- Python Artifacts ---
*.pyc
__pycache__/
# variables.py loads from environment variables, so it's safe to commit

# --- Environment Files ---
.env
.env.sh
.envs/.env*
.envs/.env.sh.*
# Keep template files
!.envs/.env.template.*
!.envs/.env.sh.template.* 
