# --- Robot Framework Artifacts ---
# Don't copy old test reports into the new image
results/**/*.xml
results/**/*.html
results/**/*.png
results/**/*.txt
log.html
report.html
output.xml
screenshots/
# Keep directory structure but ignore generated files
!results/**/suites/.gitkeep
!results/**/screenshots/.gitkeep

# --- LPAR-specific test files ---
# Ignore .robot files in all tests subdirectories
tests/**/*.robot
# But keep common tests
!tests/common/*.robot

# --- Python Artifacts ---
*.pyc
__pycache__/
variables.py

# --- Environment Files ---
.env
.env.sh
.envs/.env*
.envs/.env.sh.*
# Keep template files
!.envs/.env.template.*
!.envs/.env.sh.template.* 

# --- DevContainer Files ---
# Ignore customer-specific devcontainer.json (use template instead)
.devcontainer/devcontainer.json
# Keep template and configuration files
!.devcontainer/devcontainer.json.template
!.devcontainer/hosts.conf
!.devcontainer/setup-hosts.sh
